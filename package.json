{
  "name": "myelotrack",
  "version": "0.1.0",
  "private": true,
  "description": "Personal health-tracking app for a myeloproliferative condition (myelofibrosis/MDS).",
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "workspaces": [
    "web",
    "server"
  ],
  "scripts": {
    "dev": "npm run dev --workspace server & npm run dev --workspace web",
    "dev:web": "npm run dev --workspace web",
    "dev:server": "npm run dev --workspace server",
    "build": "npm run build --workspace web",
    "test": "npm run test --workspace server",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "eslint": "^9.9.0",
    "globals": "^15.9.0",
    "prettier": "^3.3.3"
  }
}
