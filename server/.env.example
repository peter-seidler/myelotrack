# Copy to .env and adjust. Never commit a real .env — it holds PHI credentials.

# HTTP
PORT=8787

# Data backend: "memory" (default, seeded, no DB) or "mongo".
DATA_BACKEND=memory

# MongoDB (only used when DATA_BACKEND=mongo)
MONGODB_URI=mongodb://localhost:27017/myelotrack

# CORS: comma-separated allowed origins for the web client.
CORS_ORIGINS=http://localhost:5173

# Field-level encryption key for OAuth tokens at rest — 32 bytes, base64.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
FIELD_ENCRYPTION_KEY=

# SMART on FHIR (Epic R4) — per care team. Both run Epic, so same shape, two
# registered clients. Leave blank to disable a source's connect flow.
# MSK:
MSK_FHIR_BASE_URL=
MSK_AUTHORIZE_URL=
MSK_TOKEN_URL=
MSK_CLIENT_ID=
MSK_REDIRECT_URI=http://localhost:8787/api/v1/integrations/msk/callback
MSK_SCOPES=openid fhirUser patient/Observation.read patient/MedicationRequest.read
# Capital Health:
CAPITAL_HEALTH_FHIR_BASE_URL=
CAPITAL_HEALTH_AUTHORIZE_URL=
CAPITAL_HEALTH_TOKEN_URL=
CAPITAL_HEALTH_CLIENT_ID=
CAPITAL_HEALTH_REDIRECT_URI=http://localhost:8787/api/v1/integrations/capital-health/callback
CAPITAL_HEALTH_SCOPES=openid fhirUser patient/Observation.read patient/MedicationRequest.read
